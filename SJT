                return;
            }

            const spinner = document.getElementById('loading-spinner');
            const alertBox = document.getElementById('success-alert');
            const btnStart = document.getElementById('btn-start-test');
            
            spinner.classList.remove('hidden');
            alertBox.classList.add('hidden');

            // Simulating latency of google.script.run
            setTimeout(() => {
                spinner.classList.add('hidden');
                alertBox.classList.remove('hidden');
                
                // Populate mock fields as if retrieved from spreadsheet rows
                document.getElementById('bio-nama').value = "Budi Setiawan, S.Kom";
                document.getElementById('bio-gol').value = "Penata / III-c";
                document.getElementById('bio-jabatan').value = "Pranata Komputer Ahli Muda";
                document.getElementById('bio-pd').value = "Badan Kepegawaian, Pendidikan dan Pelatihan Daerah";
                
                // Unlock Start button and apply glowing effect
                btnStart.removeAttribute('disabled');
                btnStart.classList.remove('from-slate-700', 'to-slate-800', 'text-slate-400', 'cursor-not-allowed');
                btnStart.classList.add('from-sky-500', 'to-indigo-600', 'text-slate-900', 'neon-glow-active', 'hover:opacity-90');
            }, 1200);
        }

        // 2. Action to transition views from Login to Grid Panel Exam
        function launchAssessment() {
            const nip = document.getElementById('input-nip').value;
            const kode = document.getElementById('input-kode-unik').value || "SJT-MAIN-2026";
            
            document.getElementById('display-user-info').innerText = `NIP: ${nip} | Sesi: ${kode}`;
            
            // Toggle layer views
            document.getElementById('login-page').classList.add('hidden');
            document.getElementById('exam-page').classList.remove('hidden');
            
            // Build the CAT Matrix Grid Panel Navigation
            renderNavigationGrid();
            renderQuestion();
            startTimer(5400); // 90 Minutes duration simulation
        }

        // 3. Render Grid Elements based on dynamic status Array state
        function renderNavigationGrid() {
            const gridContainer = document.getElementById('nav-grid');
            gridContainer.innerHTML = '';
            
            for (let i = 1; i <= totalQuestions; i++) {
                const btn = document.createElement('button');
                btn.type = "button";
                btn.id = `nav-btn-${i}`;
                btn.innerText = i < 10 ? `0${i}` : i;
                
                // Base structure class styling
                let baseStyle = "h-11 rounded-lg font-mono text-xs font-bold border transition-all flex items-center justify-center ";
                
                // Apply color conditions mirroring standard CAT design rules
                if (i === currentIdx) {
                    baseStyle += "border-sky-400 ring-2 ring-sky-400/30 text-sky-400 font-extrabold bg-sky-950/40";
                } else if (doubtStatus[i]) {
                    baseStyle += "bg-amber-500 border-amber-400 text-slate-900 shadow-md shadow-amber-500/10";
                } else if (userAnswers[i]) {
                    baseStyle += "bg-emerald-500 border-emerald-400 text-slate-900 shadow-md shadow-emerald-500/10";
                } else if (openedQuestions[i]) {
                    baseStyle += "bg-slate-800 border-slate-700 text-slate-300";
                } else {
                    baseStyle += "bg-slate-950/40 border-slate-800/80 text-slate-600";
                }
                
                btn.className = baseStyle;
                btn.setAttribute('onclick', `jumpToQuestion(${i})`);
                gridContainer.appendChild(btn);
            }
        }

        // 4. Render Current Question Data & Choice Checkbox Elements
        function renderQuestion() {
            document.getElementById('question-number-title').innerText = `BUTIR SOAL NO: ${currentIdx}`;
            
            // Check if mock database has the item text, otherwise use generic fallback template
            const qData = sampleQuestions[currentIdx] || {
                text: `[Contoh Butir Soal Ke-${currentIdx}] Sebagai pejabat fungsional di instansi pelayanan publik, Anda mendapati instansi mengalami pemangkasan anggaran operasional tahunan sebesar 20%. Namun, target kepuasan pelayanan masyarakat dari pimpinan daerah dinaikkan sebesar 5%. Bagaimana Anda menyikapi rancangan kerja tim Anda?`,
                choices: {
                    A: `Melakukan inovasi efisiensi internal berbasis digitalisasi tanpa biaya (Open Source) guna memangkas jalur birokrasi dan mempertahankan mutu pelayanan publik ke masyarakat.`,
                    B: `Mengajukan protes resmi tertulis kepada tim anggaran daerah agar rasio pagu anggaran dikembalikan seperti semula demi kenyamanan pelaksanaan tugas harian.`,
                    C: `Mengurangi jam kerja operasional loket luar agar beban pemakaian listrik dan fasilitas pendukung kantor berkurang drastis sesuai pagu anggaran.`,
                    D: `Menerima kondisi tersebut dengan pasrah serta menurunkan kualitas standar kualitas pelayanan karena keterbatasan dana operasional pendukung.`
                }
            };

            document.getElementById('question-text').innerText = qData.text;
            
            // Loop choices option bindings
            const alphabet = ['A', 'B', 'C', 'D'];
            alphabet.forEach(letter => {
                document.getElementById(`text-${letter}`).innerText = qData.choices[letter];
                
                // Clear state styling
                const radioBox = document.getElementById(`radio-${letter}`);
                const parentLabel = radioBox.parentElement;
                
                radioBox.className = "w-6 h-6 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center text-xs font-bold shrink-0 transition-colors group-hover:bg-slate-700 group-hover:text-sky-400 text-slate-400";
                parentLabel.className = "group flex items-start gap-4 p-4 rounded-xl bg-slate-900 border border-slate-800 hover:border-sky-500/40 cursor-pointer transition-all duration-150";
                
                // Reapply active style if selected previously
                if (userAnswers[currentIdx] === letter) {
                    radioBox.className = "w-6 h-6 rounded-lg bg-sky-500 border border-sky-400 text-slate-900 flex items-center justify-center text-xs font-black shrink-0 shadow-lg shadow-sky-500/20";
                    parentLabel.className = "group flex items-start gap-4 p-4 rounded-xl bg-sky-950/50 border-sky-500 text-white cursor-pointer transition-all duration-150 shadow-md";
                }
            });

            // Set Doubt status checkbox bindings
            document.getElementById('checkbox-doubt').checked = doubtStatus[currentIdx] || false;
            
            // Disable or Enable Prev Button based on position index bounds
            document.getElementById('btn-prev').disabled = (currentIdx === 1);
            
            // Change text of 'Next' button to 'Selesai' on final item index
            const btnNext = document.getElementById('btn-next');
            if (currentIdx === totalQuestions) {
                btnNext.innerText = "Selesai";
                btnNext.className = "px-6 py-2.5 rounded-xl bg-rose-600 hover:bg-rose-500 text-white text-sm font-bold transition-all shadow-md";
            } else {
                btnNext.innerText = "Selanjutnya";
                btnNext.className = "px-6 py-2.5 rounded-xl bg-sky-500 hover:bg-sky-400 text-slate-900 text-sm font-bold transition-all shadow-md";
            }
        }

        // 5. Select Option Choice Trigger Action Method
        function selectOption(letter) {
            userAnswers[currentIdx] = letter;
            
            // Trigger automatic background save simulation (Important for Apps Script sync)
            simulateBackgroundSave(currentIdx, letter);
            
            // Refresh visuals layout views
            renderQuestion();
            renderNavigationGrid();
        }

        // 6. Simulate Apps Script network background submission activity 
        function simulateBackgroundSave(questionNum, choiceValue) {
            const statusIndicator = document.getElementById('sync-status');
            statusIndicator.innerText = "Saving...";
            statusIndicator.parentElement.classList.replace('bg-emerald-500/10', 'bg-amber-500/10');
            statusIndicator.parentElement.classList.replace('border-emerald-500/20', 'border-amber-500/20');
            statusIndicator.parentElement.classList.replace('text-emerald-400', 'text-amber-400');
            
            // Mock server roundtrip interval
            setTimeout(() => {
                statusIndicator.innerText = "Saved to Cloud";
                statusIndicator.parentElement.classList.replace('bg-amber-500/10', 'bg-emerald-500/10');
                statusIndicator.parentElement.classList.replace('border-amber-500/20', 'border-emerald-500/20');
                statusIndicator.parentElement.classList.replace('text-amber-400', 'text-emerald-400');
            }, 600);
        }

        // 7. Toggle Checked Box Doubt Status state
        function toggleDoubtful() {
            const currentDoubt = doubtStatus[currentIdx] || false;
            doubtStatus[currentIdx] = !currentDoubt;
            
            renderQuestion();
            renderNavigationGrid();
        }

        // 8. Handle Index Increment/Decrement Button Navigation clicks
        function navigateQuestion(direction) {
            if (direction === 1 && currentIdx === totalQuestions) {
                triggerFinishAssessment();
                return;
            }
            
            currentIdx += direction;
            if (currentIdx < 1) currentIdx = 1;
            if (currentIdx > totalQuestions) currentIdx = totalQuestions;
            
            openedQuestions[currentIdx] = true;
            renderQuestion();
            renderNavigationGrid();
        }

        // 9. Directly jump mapping index via grid circle numbers
        function jumpToQuestion(targetIndex) {
            currentIdx = targetIndex;
            openedQuestions[currentIdx] = true;
            renderQuestion();
            renderNavigationGrid();
        }

        // 10. Countdown Digital Timer Engine Function Loops
        function startTimer(durationInSeconds) {
            let timer = durationInSeconds;
            const display = document.getElementById('countdown-timer');
            
            const intervalId = setInterval(() => {
                let minutes = parseInt(timer / 60, 10);
                let seconds = parseInt(timer % 60, 10);

                minutes = minutes < 10 ? "0" + minutes : minutes;
                seconds = seconds < 10 ? "0" + seconds : seconds;

                display.textContent = minutes + ":" + seconds;

                // Color flash alert warning text below 5 minutes left thresholds
                if (timer < 300) {
                    display.classList.replace('text-sky-400', 'text-rose-500');
                }

                if (--timer < 0) {
                    clearInterval(intervalId);
                    alert("Waktu pengerjaan asesmen telah habis! Sistem otomatis menyimpan jawaban terakhir.");
                    submitAllDataFinal();
                }
            }, 1000);
        }

        // 11. Final Assessment Actions Submissions Hook 
        function triggerFinishAssessment() {
            const unanswered = totalQuestions - Object.keys(userAnswers).length;
            let warningText = "Apakah Anda yakin ingin menyelesaikan dan mengirim seluruh rangkaian lembar jawaban SJT?";
            if (unanswered > 0) {
                warningText += `\n\nPERINGATAN: Masih ada ${unanswered} butir soal yang belum diisi!`;
            }

            if (confirm(warningText)) {
                submitAllDataFinal();
            }
        }

        // 12. Final execution screen routing
        function submitAllDataFinal() {
            // In production, this runs google.script.run.saveFinalAnswers(userAnswers)
            document.body.innerHTML = `
                <div class="min-h-screen flex flex-col items-center justify-center bg-[#0b132b] text-slate-200 p-6 text-center">
                    <div class="p-4 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 mb-4 animate-bounce">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h1 class="heading-font text-2xl md:text-3xl font-extrabold text-white mb-2">ASESMEN SELESAI & TERSIMPAN</h1>
                    <p class="text-sm text-slate-400 max-w-md mx-auto leading-relaxed">
                        Terima kasih, lembar jawaban Situational Judgment Test (SJT) Anda telah berhasil dikunci dan dikirimkan langsung ke pangkalan data Spreadsheet BKPSDM.
                    </p>
                    <div class="mt-6 p-4 rounded-xl bg-slate-900 border border-slate-800 text-left text-xs font-mono max-w-sm w-full space-y-1.5">
                        <div class="text-sky-400 border-b border-slate-800 pb-1 font-bold">BUKTI DIGITAL (TOKEN):</div>
                        <div>Status: SUCCESS (200)</div>
                        <div>Timestamp: ${new Date().toISOString()}</div>
                        <div>Items Saved: ${Object.keys(userAnswers).length} / ${totalQuestions}</div>
                    </div>
                </div>
            `;
        }
    </script>
</body>
</html>
